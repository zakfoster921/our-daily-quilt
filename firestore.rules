rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isDateKey(id) {
      return id.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    match /quilts/{dateKey} {
      allow read: if true;
      // Prevent stale browser/client bundles from clearing production quilts.
      // Admin SDK/server resets bypass Firestore rules, so scheduled resets still work.
      allow create, update: if request.resource.data.blocks is list
        && request.resource.data.blocks.size() > 0;
      allow delete: if false;
    }

    match /quiltNames/{dateKey} {
      allow read: if true;
      allow create, update: if request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100;
      allow delete: if false;
    }

    match /quotes/{quoteId} {
      allow read: if true;
      // Date-shaped quote docs are daily state and must not be overwritten by stale clients.
      // Server/Admin SDK maintenance bypasses rules; non-date catalog quote docs keep prior behavior.
      allow create, update, delete: if !isDateKey(quoteId);
    }

    match /dailyQuoteAssignments/{dateKey} {
      // Public daily quote state, written only by server/Admin SDK sync jobs.
      allow read: if true;
      allow write: if false;
    }

    match /dailyQuoteUsage/{dateKey} {
      // Public read-only usage metadata for app display; server/Admin SDK writes.
      allow read: if true;
      allow write: if false;
    }

    match /archives/{dateKey} {
      // Public archive content, written only by server/Admin SDK reset/backfill jobs.
      allow read: if true;
      allow write: if false;
    }

    match /instagram-images/{dateKey} {
      allow read: if true;
      // The app's image pipeline signs in anonymously before uploading Storage assets
      // and merging URL fields here. Server/Admin SDK writes bypass these rules.
      allow create, update: if isSignedIn() && isDateKey(dateKey);
      allow delete: if false;
    }

    match /reflectionResponses/{responseId} {
      // Private raw user reflections: server/Admin SDK writes only.
      allow read, write: if false;
    }

    match /reflectionThemes/{dateKey} {
      allow read: if true;
      // Public generated themes, written only by the server/Admin SDK.
      allow write: if false;
    }

    match /socialPosts/{postId} {
      allow read: if true;
      allow write: if false;
    }

    match /socialPosts/{postId}/comments/{commentId} {
      allow read: if true;
      allow write: if false;
    }

    match /colorMilestoneNotifications/{notificationId} {
      // Best-effort client analytics. Never required for core quilt saving.
      allow create, update: if true;
      allow read, delete: if false;
    }

    match /popularColorResponses/{dateKey}/responses/{responseId} {
      // Disabled in the current UI, but keep the narrow write path explicit.
      allow create: if true;
      allow read, update, delete: if false;
    }

    match /pushTokens/{tokenId} {
      // Push tokens are registered through the Express API.
      allow read, write: if false;
    }

    match /ops/{opId} {
      // Operational idempotency/status docs are server/Admin SDK only.
      allow read, write: if false;
    }

    match /quoteSubmissions/{submissionId} {
      // Quote submissions are created through the Express API.
      allow read, write: if false;
    }

    match /{collection}/{document=**} {
      // Hotfix: the monolith still has a few startup reads that are easy to miss.
      // Keep unknown client writes closed, but allow public reads outside private/server-only collections.
      allow read: if collection != 'reflectionResponses'
        && collection != 'pushTokens'
        && collection != 'ops'
        && collection != 'quoteSubmissions'
        && collection != 'colorMilestoneNotifications'
        && collection != 'popularColorResponses'
        && collection != 'socialPosts';
      allow write: if false;
    }
  }
}
