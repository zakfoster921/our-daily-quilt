{
  "name": "instagram-quilt-generator",
  "version": "1.0.0",
  "description": "Instagram image generator for Our Daily Quilt",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "curl http://localhost:3000/api/health",
    "build:www": "node scripts/build-www.mjs",
    "cap:sync": "npm run build:www && npx cap sync",
    "ios": "bash scripts/release-ios-prep.sh",
    "ios:open": "bash scripts/release-ios-prep.sh --open",
    "release:ios": "npm run ios",
    "release:ios:open": "npm run ios:open",
    "release:android": "npm run build:www && npx cap sync android",
    "ssr:reel": "node scripts/generate-ssr-reel.cjs",
    "sync:quotes": "node scripts/sync-notion-to-firestore.cjs",
    "sync:quotes:dry": "node scripts/sync-notion-to-firestore.cjs --dry-run",
    "sync:usage": "node scripts/sync-usage-firestore-to-notion.cjs",
    "sync:usage:dry": "node scripts/sync-usage-firestore-to-notion.cjs --dry-run",
    "schedule:app-submissions": "node scripts/schedule-approved-app-submissions.cjs --start=today --cadence=1 --window=8",
    "schedule:app-submissions:dry": "node scripts/schedule-approved-app-submissions.cjs --start=today --cadence=1 --window=8 --dry-run",
    "schedule:rolling": "node scripts/backfill-daily-assignments.cjs --start=today --cadence=1 --window=8",
    "schedule:rolling:dry": "node scripts/backfill-daily-assignments.cjs --start=today --cadence=1 --window=8 --dry-run",
    "assign:all:daily": "node scripts/schedule-approved-app-submissions.cjs --start=today --cadence=1 --window=8 && node scripts/backfill-daily-assignments.cjs --start=today --cadence=1 --window=8 --sync-notion",
    "assign:all:daily:dry": "node scripts/schedule-approved-app-submissions.cjs --start=today --cadence=1 --window=8 --dry-run && node scripts/backfill-daily-assignments.cjs --start=today --cadence=1 --window=8 --dry-run"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^7.5.0",
    "@capacitor/local-notifications": "^7.0.6",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "canvas": "^2.11.2",
    "express": "^4.18.2",
    "firebase": "^11.10.0",
    "firebase-admin": "^11.11.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "nodemon": "^3.0.1",
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "instagram",
    "quilt",
    "automation",
    "zapier"
  ],
  "author": "Zak Foster",
  "license": "MIT"
}
