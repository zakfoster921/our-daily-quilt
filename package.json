{
  "name": "instagram-quilt-generator",
  "version": "1.0.0",
  "description": "Instagram image generator for Our Daily Quilt",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "curl http://localhost:3000/api/health",
    "build:www": "node scripts/build-www.mjs",
    "cap:sync": "npm run build:www && npx cap sync",
    "ssr:reel": "node scripts/generate-ssr-reel.cjs",
    "sync:quotes": "node scripts/sync-notion-to-firestore.cjs",
    "sync:quotes:dry": "node scripts/sync-notion-to-firestore.cjs --dry-run",
    "sync:usage": "node scripts/sync-usage-firestore-to-notion.cjs",
    "sync:usage:dry": "node scripts/sync-usage-firestore-to-notion.cjs --dry-run"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "canvas": "^2.11.2",
    "express": "^4.18.2",
    "firebase-admin": "^11.11.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "nodemon": "^3.0.1",
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "instagram",
    "quilt",
    "automation",
    "zapier"
  ],
  "author": "Zak Foster",
  "license": "MIT"
}
