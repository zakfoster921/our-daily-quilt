{
  "name": "instagram-quilt-generator",
  "version": "1.0.0",
  "description": "Instagram image generator for Our Daily Quilt",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "editor": "bash scripts/odq-editor.sh",
    "dev": "nodemon server.js",
    "dev:static": "node scripts/static-dev-server.cjs",
    "test": "npm run test:ci",
    "test:ci": "node scripts/smoke-ci.cjs",
    "test:health": "curl -fsS http://localhost:3000/api/health",
    "build:www": "node scripts/build-www.mjs",
    "cap:sync": "npm run build:www && npx cap sync",
    "ios": "bash scripts/release-ios-prep.sh",
    "ios:open": "bash scripts/release-ios-prep.sh --open",
    "ios:archive": "bash scripts/archive-ios-appstore.sh",
    "ios:upload": "bash scripts/upload-ios-appstore.sh",
    "ios:verify-push": "node scripts/verify-ios-push-entitlement.cjs",
    "ios:bump-version": "node scripts/ios-version.cjs bump",
    "ios:shipped": "node scripts/ios-version.cjs shipped",
    "release:ios": "npm run ios",
    "release:ios:open": "npm run ios:open",
    "release:android": "npm run build:www && npx cap sync android",
    "ssr:reel": "node scripts/generate-ssr-reel.cjs",
    "nightly:ig-images": "node scripts/generate-nightly-ig-images.cjs",
    "nightly:newspaper-clipping": "NIGHTLY_IG_CLIPPING_ONLY=true NIGHTLY_IG_SKIP_SCHEDULE_GUARD=true node scripts/generate-nightly-ig-images.cjs",
    "cron:daily-reset": "node scripts/trigger-daily-reset.cjs",
    "smoke:deps": "node scripts/smoke-deps.cjs",
    "smoke:mood-clipping": "node scripts/smoke-quilt-mood-clipping.cjs",
    "screenshot:screens": "node scripts/screenshot-all-screens.cjs",
    "preview:week-quilt-screens": "node scripts/preview-week-quilt-screens.cjs",
    "render:library-pocket": "node scripts/render-library-pocket-empty.cjs",
    "sync:quotes": "node scripts/sync-notion-to-firestore.cjs --start=today --window=7",
    "sync:quotes:dry": "node scripts/sync-notion-to-firestore.cjs --start=today --window=7 --dry-run",
    "sync:quotes:full": "node scripts/sync-notion-to-firestore.cjs --full-catalog",
    "backfill:first-line-count": "node scripts/backfill-first-line-count-from-notion.cjs",
    "sync:usage": "node scripts/sync-usage-firestore-to-notion.cjs --start=today --window=7",
    "sync:usage:dry": "node scripts/sync-usage-firestore-to-notion.cjs --start=today --window=7 --dry-run",
    "sync:usage:full": "node scripts/sync-usage-firestore-to-notion.cjs --full-catalog",
    "reconcile:assignment-dates": "node scripts/reconcile-assignment-dates-from-notion.cjs --start=today",
    "reconcile:assignment-dates:dry": "node scripts/reconcile-assignment-dates-from-notion.cjs --start=today --dry-run",
    "speaker:cutouts": "node scripts/process-speaker-cutouts.cjs",
    "speaker:cutouts:dry": "node scripts/process-speaker-cutouts.cjs --dry-run",
    "speaker:repair": "node scripts/repair-speaker-cutout.cjs --date=today",
    "speaker:repair:dry": "node scripts/repair-speaker-cutout.cjs --date=today --dry-run",
    "reviewed:quote-assets": "node scripts/process-reviewed-quote-assets.cjs",
    "schedule:app-submissions": "node scripts/schedule-approved-app-submissions.cjs --start=today --cadence=1 --window=8",
    "schedule:app-submissions:dry": "node scripts/schedule-approved-app-submissions.cjs --start=today --cadence=1 --window=8 --dry-run",
    "schedule:rolling": "node scripts/backfill-daily-assignments.cjs --start=today --cadence=1 --window=8",
    "schedule:rolling:dry": "node scripts/backfill-daily-assignments.cjs --start=today --cadence=1 --window=8 --dry-run",
    "normalize:snake-case": "node scripts/normalize-firestore-snake-case.cjs --commit",
    "normalize:snake-case:dry": "node scripts/normalize-firestore-snake-case.cjs",
    "cleanup:instagram-zapier:dry": "node scripts/cleanup-instagram-zapier-versioned-assets.cjs",
    "cleanup:instagram-zapier": "node scripts/cleanup-instagram-zapier-versioned-assets.cjs --commit",
    "assign:all:daily": "node scripts/schedule-approved-app-submissions.cjs --start=today --cadence=1 --window=8 && node scripts/backfill-daily-assignments.cjs --start=today --cadence=1 --window=8 --sync-notion",
    "assign:all:daily:dry": "node scripts/schedule-approved-app-submissions.cjs --start=today --cadence=1 --window=8 --dry-run && node scripts/backfill-daily-assignments.cjs --start=today --cadence=1 --window=8 --dry-run"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^7.5.0",
    "@capacitor/local-notifications": "^7.0.6",
    "@capacitor/splash-screen": "^7.0.5",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "canvas": "^2.11.2",
    "express": "^4.22.2",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.10.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "nodemon": "^3.0.1",
    "playwright": "^1.60.0"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [
    "instagram",
    "quilt",
    "automation",
    "zapier"
  ],
  "author": "Zak Foster",
  "license": "MIT"
}
