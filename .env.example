NOTION_TOKEN=ntn_your_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
FIRESTORE_QUOTES_COLLECTION=quotes
FIRESTORE_DAILY_QUOTES_COLLECTION=dailyQuoteUsage
# Optional: POST /api/sync-notion-firestore (admin button). If unset, RESET_TOKEN is accepted instead.
NOTION_SYNC_TOKEN=
# Optional: absolute path to an MP3/WAV for reel bed audio fallback.
# REEL_BED_MUSIC_PATH=
# Optional: JSON mood->absolute file path map for reel music selection.
# Example: {"calm":"/Users/me/audio/calm.mp3","tense":"/Users/me/audio/tense.mp3","joyful":"/Users/me/audio/joyful.mp3","reflective":"/Users/me/audio/reflective.mp3","bold":"/Users/me/audio/bold.mp3","default":"/Users/me/audio/default.mp3"}
# REEL_BED_MUSIC_PATHS_JSON=
# Unknown/blank/typo mood labels automatically fall back to "default".
# Built-in mood aliases: calm/reflective->contemplative, uplifting/powerful->empowering, bold/energetic->mobilizing, gentle->nurturing.
# ODQ production example (Railway/GitHub runtime path):
# REEL_BED_MUSIC_PATHS_JSON={"contemplative":"/app/assets/audio/contemplative-20s.mp3","empowering":"/app/assets/audio/empowering-20s.mp3","expansive":"/app/assets/audio/expansive-20s.mp3","mobilizing":"/app/assets/audio/mobilizing-20s.mp3","nurturing":"/app/assets/audio/nurturing-20s.mp3","default":"/app/assets/audio/contemplative-20s.mp3"}
# ODQ local example:
# REEL_BED_MUSIC_PATHS_JSON={"contemplative":"/Users/zakfoster/Desktop/our-daily-improved/assets/audio/contemplative-20s.mp3","empowering":"/Users/zakfoster/Desktop/our-daily-improved/assets/audio/empowering-20s.mp3","expansive":"/Users/zakfoster/Desktop/our-daily-improved/assets/audio/expansive-20s.mp3","mobilizing":"/Users/zakfoster/Desktop/our-daily-improved/assets/audio/mobilizing-20s.mp3","nurturing":"/Users/zakfoster/Desktop/our-daily-improved/assets/audio/nurturing-20s.mp3","default":"/Users/zakfoster/Desktop/our-daily-improved/assets/audio/contemplative-20s.mp3"}
